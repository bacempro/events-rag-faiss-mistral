# ──────────────────────────────────────────────────────────────────────────────
# OpenAgenda API
# Required only for scripts/fetch_openagenda_events.py (data extraction step).
# Get your key at https://openagenda.com/developers
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Your OpenAgenda API key
OPENAGENDA_API_KEY=

# Slug of the agenda to query (resolved to a UID at fetch time)
OPENAGENDA_AGENDA_SLUG=culture

# City filter applied in the API request
OPENAGENDA_CITY=Paris

# Number of events fetched per API page (max supported by OpenAgenda v2: 300)
OPENAGENDA_PAGE_SIZE=100

# Maximum number of pages to fetch (safety cap — increase if the agenda grows)
OPENAGENDA_MAX_PAGES=20


# ──────────────────────────────────────────────────────────────────────────────
# Mistral API
# Required from Step 3 onward (embeddings + answer generation).
# Get your key at https://console.mistral.ai
# ──────────────────────────────────────────────────────────────────────────────

# [REQUIRED] Your Mistral API key
MISTRAL_API_KEY=

# Embedding model used to build and query the FAISS vectorstore.
# Must stay consistent between build (scripts/build_faiss_index.py) and query time.
# Available: mistral-embed
MISTRAL_EMBEDDING_MODEL=mistral-embed

# Chat model used for answer generation.
# Available options: mistral-small-latest, mistral-medium-latest, mistral-large-latest
MISTRAL_CHAT_MODEL=mistral-small-latest


# ──────────────────────────────────────────────────────────────────────────────
# RAG pipeline configuration
# Controls retrieval depth and generation behaviour at query time.
# ──────────────────────────────────────────────────────────────────────────────

# Number of chunks retrieved per query (can be overridden with --top-k at CLI)
RAG_TOP_K=5

# Chat model temperature — 0.0 gives deterministic, grounded answers
RAG_TEMPERATURE=0.0


# ──────────────────────────────────────────────────────────────────────────────
# FAISS vectorstore
# Controls how event texts are chunked before embedding (build step only).
# Changes here require a full vectorstore rebuild (scripts/build_faiss_index.py).
# ──────────────────────────────────────────────────────────────────────────────

# Maximum characters per text chunk
FAISS_CHUNK_SIZE=1000

# Character overlap between consecutive chunks (preserves context at boundaries)
FAISS_CHUNK_OVERLAP=150

# Optional: override the default vectorstore path (default: vectorstore/faiss_index)
# FAISS_INDEX_PATH=vectorstore/faiss_index
